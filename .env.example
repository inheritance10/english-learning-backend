# App
NODE_ENV=production
PORT=3000
APP_NAME=LangLearn API

# Database (Railway sağlayacak)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=langlearndb

# Redis (opsiyonel, Redis url varsa kullan, yoksa memory cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

# Firebase Admin SDK
FIREBASE_PROJECT_ID=langlearnapp-81030
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@langlearnapp-81030.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=

# Google Gemini AI
GEMINI_API_KEY=

# Apple IAP
APPLE_SHARED_SECRET=
APPLE_VERIFY_RECEIPT_URL=https://sandbox.itunes.apple.com/verifyReceipt

# Google Play IAP
GOOGLE_PLAY_PACKAGE_NAME=com.alicebeci.langlearn
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY={}

# Trial
TRIAL_DURATION_DAYS=7
